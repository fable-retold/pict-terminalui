{
    "name": "pict-terminalui",
    "version": "0.0.2",
    "description": "Pict Terminal UI - Blessed-based terminal interface for Pict views",
    "main": "source/Pict-TerminalUI.js",
    "scripts": {
        "start": "node example/Example-App.js",
        "test": "npx quack test",
        "tests": "npx quack test -g",
        "coverage": "npx quack coverage",
        "build": "npx quack build",
        "docs": "npx quack prepare-docs ./docs -d ./modules",
        "docs-serve": "npx quack docs-serve ./docs"
    },
    "author": "steven velozo <steven@velozo.com>",
    "license": "MIT",
    "dependencies": {
        "blessed": "^0.1.81",
        "fable": "^3.0.232",
        "fable-serviceproviderbase": "^3.0.16",
        "pict": "^1.0.343",
        "pict-application": "^1.0.28",
        "pict-view": "^1.0.64"
    },
    "devDependencies": {
        "quackage": "^1.0.58"
    },
    "mocha": {
        "diff": true,
        "extension": [
            "js"
        ],
        "package": "./package.json",
        "reporter": "spec",
        "slow": "75",
        "timeout": "5000",
        "ui": "tdd",
        "watch-files": [
            "source/**/*.js",
            "test/**/*.js"
        ],
        "watch-ignore": [
            "lib/vendor"
        ]
    }
}